# --- AI Provider Configuration ---
# Validated options exposed in the app: google_ai_studio, mistral, openrouter

# Google AI Studio / Gemini API
GOOGLE_AI_STUDIO_API_KEY=your_gemini_key
GEMINI_API_KEY=your_gemini_key

# Mistral
MISTRAL_API_KEY=your_mistral_key

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Optional: Set defaults if not using Monolith UI Config
DEFAULT_PROVIDER="google_ai_studio"
DEFAULT_MODEL="gemini-2.5-flash"

# --- Monolith Configuration ---
MONGODB_URL=mongodb://localhost:27017/trader_db
