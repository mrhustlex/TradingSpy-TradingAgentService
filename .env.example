# Copy this file to .env and add one provider key.
# Keys can also be configured later in the app under Settings.

# Google AI Studio (recommended first setup)
GOOGLE_AI_STUDIO_API_KEY=
# GEMINI_API_KEY is accepted as an alias. You only need one of these two.
GEMINI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# NVIDIA
NVIDIA_API_KEY=

# LiteLLM proxy
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000/v1

# Ollama (no API key required). The Docker backend reaches host Ollama here.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

DEFAULT_PROVIDER=google_ai_studio
DEFAULT_MODEL=gemini-2.5-flash

# Optional remote-agent protection. Keep remote outputs bound to localhost even
# when this is set; see SECURITY.md before exposing any service.
REMOTE_AGENT_AUTH_TOKEN=

# Optional runtime tuning
LOG_LEVEL=INFO
