# --- AI Provider Configuration ---
# Options: openai, openrouter, groq, google_ai_studio, litellm, azure, aws, gcp, mistral

# OpenAI
OPENAI_API_KEY=sk-...

# OpenRouter / Groq / Mistral
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=your_key

# Google AI Studio / Gemini API
GOOGLE_AI_STUDIO_API_KEY=your_gemini_key
GEMINI_API_KEY=your_gemini_key

# LiteLLM Proxy
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# AWS Bedrock
AWS_ACCESS_KEY_ID=your_id
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1

# GCP Vertex AI
# Vertex AI uses Application Default Credentials or a service account in the container.
# Use Google AI Studio above for API-key Gemini.
GCP_PROJECT=your-project-id
GCP_LOCATION=us-central1
GCP_API_KEY=

# Optional: Set defaults if not using Monolith UI Config
DEFAULT_PROVIDER="openai"
DEFAULT_MODEL="gpt-4o"

# --- Monolith Configuration ---
MONGODB_URL=mongodb://localhost:27017/trader_db
